Exclude jemalloc and Linux-only memory tracking on all Windows targets.

The original cfg `not(target_env = "msvc")` only excluded MSVC, allowing
jemalloc on windows-gnu (MinGW).  However, the memory tracker uses
Linux-only APIs (/proc/pid/statm, libc::sysconf, libc::pid_t) that do
not exist on any Windows variant.  CKB's official Windows builds (MSVC)
already excluded jemalloc; this extends the exclusion to windows-gnu.

Additionally, check_msvc_version() uses `winreg` and `version-compare`
crates which are gated behind cfg(target_env = "msvc"), but the function
itself was gated with cfg(target_os = "windows") — causing unresolved
imports on windows-gnu.  Fixed to cfg(target_env = "msvc").

diff --git a/Cargo.toml b/Cargo.toml
index 5e5b98e..0fa7df4 100644
--- a/Cargo.toml
+++ b/Cargo.toml
@@ -30,7 +30,7 @@ console-subscriber = { workspace = true, optional = true }
 winreg = "0.55"
 version-compare = "0.2"
 
-[target.'cfg(all(not(target_env = "msvc"), not(target_os="macos")))'.dependencies]
+[target.'cfg(all(not(target_os = "windows"), not(target_os="macos")))'.dependencies]
 tikv-jemallocator = { version = "0.5.0", features = [
   "unprefixed_malloc_on_supported_platforms",
 ] }
